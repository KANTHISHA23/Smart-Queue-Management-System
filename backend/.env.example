# Server
PORT=5000
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@your-neon-host/neondb?sslmode=require
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# Frontend URL (Vercel). Backward-compatible alias: CORS_ORIGIN
CLIENT_URL=https://your-frontend.vercel.app

# ML wait-time prediction (optional — falls back to heuristic if unavailable)
ML_SERVICE_URL=http://localhost:8001
ML_PREDICTION_ENABLED=true
ML_TIMEOUT_MS=2000
